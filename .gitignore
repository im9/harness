# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# Test / lint caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/
.mypy_cache/

# Build output
build/
dist/

# Node / Vite
node_modules/
.vite/

# Local databases
*.db
*.sqlite
*.sqlite3

# Environment (keep .env.example tracked)
.env
.env.*
!.env.example

# Dev server PIDs / logs (Makefile dev-up)
.dev/

# Operator-private notes and config.
# ADR 004 mandates that operator-specific values (loss thresholds,
# instrument choices, session windows, vendor selection) are loaded at
# runtime from config, never hardcoded. The operator's filled-in config
# lives here and must never be committed.
docs/private/
config/harness.yaml
config/help-entries.yaml

# Editors
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
