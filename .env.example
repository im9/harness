# Copy to .env and fill in values. Never commit .env.

# --- Database ---
# SQLite path with async driver (aiosqlite). Relative to repo root or absolute.
DATABASE_URL=sqlite+aiosqlite:///./harness.db

# --- Auth ---
# JWT signing secret (≥32 bytes per ADR 001 §Authentication). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
HARNESS_JWT_SECRET=

# --- Notifications ---
# Generic webhook URL for the messaging app integration (pluggable).
NOTIFIER_WEBHOOK_URL=

# --- Server ---
HOST=127.0.0.1
PORT=8787
