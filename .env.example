# Copy to .env and fill in values. Never commit .env.

# --- Database ---
# SQLite path with async driver (aiosqlite). Relative to repo root or absolute.
DATABASE_URL=sqlite+aiosqlite:///./harness.db

# --- Auth ---
# JWT signing secret. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
# JWT token lifetime in minutes.
JWT_EXPIRES_MINUTES=60
# TOTP issuer name shown in the authenticator app.
TOTP_ISSUER=harness

# --- Notifications ---
# Generic webhook URL for the messaging app integration (pluggable).
NOTIFIER_WEBHOOK_URL=

# --- Server ---
HOST=127.0.0.1
PORT=8000
